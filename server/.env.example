# PRODUCTION SECURITY CONFIGURATION
# 
# NEVER commit actual secrets to version control.
# Use this file as a template for your environment configuration.
# Copy to .env and fill in with actual values.
#
# CRITICAL: All values marked [REQUIRED] must be set in production.

# ===== APPLICATION CONFIGURATION =====

# Application environment
# Values: development, staging, production
NODE_ENV=development

# Server port
PORT=4000

# ===== DATABASE CONFIGURATION [REQUIRED] =====
#
# PostgreSQL connection string
# Format: postgresql://[user][:password]@[host][:port]/[database]
# 
# SECURITY: 
# - Use strong passwords
# - Restrict database access by IP
# - Use SSL/TLS for database connections in production
# - Never use the postgres superuser for app connections
#
DATABASE_URL=postgresql://user:password@localhost:5432/scs_inventory

# ===== JWT CONFIGURATION [REQUIRED] =====
#
# Secret key for signing JWT tokens
# SECURITY CRITICAL:
# - Must be at least 32 characters (256 bits) in production
# - Use cryptographically secure random generation
# - Rotate periodically (invalidates all existing tokens)
# - Keep extremely secret - treat like a password
# - Store in secure secret management system (Vault, AWS Secrets Manager, etc.)
#
# Generate with: openssl rand -base64 32
#
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long

# JWT expiration time
# Values: 7d, 24h, 1h, etc. (see node-jwt docs)
JWT_EXPIRES_IN=7d

# ===== SUPER ADMIN CONFIGURATION [REQUIRED] =====
#
# Super admin email for initial setup
# SECURITY: Use a corporate email address
#
SUPER_ADMIN_EMAIL=admin@company.com

# Super admin password for initial setup
# SECURITY:
# - Must be at least 8 characters
# - Preferably generated randomly and stored securely
# - Change after first login
# - Never share or log in plain text
#
# Generate with: openssl rand -base64 16 | tr '/' '_'
#
SUPER_ADMIN_PASSWORD=SecureP@ssw0rd123

# ===== CORS CONFIGURATION =====
#
# Allowed origins for CORS requests (comma-separated)
# SECURITY: 
# - Restrict to specific frontend domains only
# - Never use * (wildcard) in production
# - Always use HTTPS in production
#
# Example for multiple environments:
# CORS_ORIGINS=https://app.example.com,https://admin.example.com
#
CORS_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:3003

# ===== SECURITY NOTES =====
#
# 1. ENVIRONMENT VARIABLES
#    - Load .env files only from secure, restricted filesystem
#    - Never log environment variables
#    - Rotate sensitive values periodically
#    - Monitor access to .env files
#
# 2. PRODUCTION DEPLOYMENT
#    - Use container secrets or environment variable management
#    - Examples: Docker secrets, Kubernetes secrets, AWS Secrets Manager
#    - Never commit .env files to git (they're in .gitignore for this reason)
#    - Use separate credentials for each environment
#
# 3. DATABASE SECURITY
#    - Use VPN/bastion host for database access
#    - Enable SSL/TLS for all database connections
#    - Restrict database user permissions to minimum needed
#    - Enable database audit logging
#    - Regular backups and encryption at rest
#
# 4. JWT SECRETS
#    - Store in secure key management system
#    - Implement key rotation strategy
#    - Monitor for unauthorized token creation
#    - Implement refresh token rotation
#    - Logout mechanism revokes all sessions server-side
#
# 5. ADMIN CREDENTIALS
#    - Use SSO/OAuth when possible (reduces password storage)
#    - Enforce strong password policies
#    - Implement MFA/2FA for super admin
#    - Audit all super admin actions (already logged)
#    - Monitor for suspicious patterns
#
# 6. COMPLIANCE
#    - GDPR: Personal data handling and retention
#    - SOC 2: Security controls and monitoring
#    - ISO 27001: Information security management
#    - Regular security audits and penetration tests
