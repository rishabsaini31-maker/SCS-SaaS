generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum BusinessType {
  WHOLESALE_DISTRIBUTOR
  GROCERY
  CLOTHING
  ELECTRONICS
  MEDICAL
  HARDWARE
  STATIONERY
  MOBILE
  COSMETICS
  RESTAURANT
  GENERAL_RETAIL
}

model Product {
  id            String             @id @default(cuid())
  name          String
  category      String?
  purchasePrice Float              @default(0)
  sellingPrice  Float              @default(0)
  gst           Float              @default(0)
  stock         Int                @default(0)
  barcode       String?
  image         String?
  expiryDate    DateTime?
  customFields  Json?
  status        String             @default("active")
  tenantId      String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  invoiceItems  InvoiceLineItem[]
  tenant        Tenant?            @relation(fields: [tenantId], references: [id])
  purchaseItems PurchaseLineItem[]
  priceOverrides PriceOverrideLog[]

  @@unique([barcode, tenantId])
  @@index([tenantId])
}

model Category {
  id        String   @id @default(cuid())
  tenantId  String?
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Customer {
  id                 String        @id @default(cuid())
  name               String
  email              String?
  phone              String?
  address            String?
  gstin              String?
  outstandingBalance Float         @default(0)
  status             String        @default("active")
  tenantId           String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  tenant             Tenant?       @relation(fields: [tenantId], references: [id])
  invoices           Invoice[]
  ledgers            LedgerEntry[]
  payments           Payment[]

  @@unique([email, tenantId])
  @@unique([gstin, tenantId])
  @@index([tenantId])
}

model Supplier {
  id             String        @id @default(cuid())
  name           String
  email          String?
  phone          String?
  address        String?
  gstin          String?
  payableBalance Float         @default(0)
  status         String        @default("active")
  tenantId       String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  ledgers        LedgerEntry[]
  payments       Payment[]
  purchases      Purchase[]
  tenant         Tenant?       @relation(fields: [tenantId], references: [id])

  @@unique([email, tenantId])
  @@unique([gstin, tenantId])
  @@index([tenantId])
}

model Invoice {
  id            String            @id @default(cuid())
  invoiceNumber String
  tenantId      String?
  customerId    String
  invoiceDate   DateTime          @default(now())
  subtotal      Float             @default(0)
  gstAmount     Float             @default(0)
  totalAmount   Float             @default(0)
  status        String            @default("created")
  notes         String?
  createdByStaffId   String?
  createdByStaffName String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  customer      Customer          @relation(fields: [customerId], references: [id])
  tenant        Tenant?           @relation(fields: [tenantId], references: [id])
  lineItems     InvoiceLineItem[]
  ledger        LedgerEntry?
  payments      Payment[]
  priceOverrides PriceOverrideLog[]

  @@unique([invoiceNumber, tenantId])
  @@index([customerId])
  @@index([tenantId])
}

model InvoiceLineItem {
  id         String   @id @default(cuid())
  tenantId   String?
  invoiceId  String
  productId  String
  quantity        Int
  originalPrice   Float?
  unitPrice       Float
  discountAmount  Float?   @default(0)
  totalPrice      Float
  createdAt  DateTime @default(now())
  invoice    Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id])
  tenant     Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([invoiceId])
  @@index([productId])
  @@index([tenantId])
}

model Purchase {
  id             String             @id @default(cuid())
  purchaseNumber String
  tenantId       String?
  supplierId     String
  purchaseDate   DateTime           @default(now())
  subtotal       Float              @default(0)
  gstAmount      Float              @default(0)
  totalAmount    Float              @default(0)
  status         String             @default("created")
  notes          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  ledger         LedgerEntry?
  payments       Payment[]
  supplier       Supplier           @relation(fields: [supplierId], references: [id])
  tenant         Tenant?            @relation(fields: [tenantId], references: [id])
  lineItems      PurchaseLineItem[]

  @@unique([purchaseNumber, tenantId])
  @@index([supplierId])
  @@index([tenantId])
}

model PurchaseLineItem {
  id          String   @id @default(cuid())
  tenantId    String?
  purchaseId  String
  productId   String?
  productName String?
  category    String?
  quantity    Int
  unitPrice   Float
  totalPrice  Float
  createdAt   DateTime @default(now())
  product     Product? @relation(fields: [productId], references: [id])
  purchase    Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([purchaseId])
  @@index([productId])
  @@index([tenantId])
}

model Payment {
  id            String       @id @default(cuid())
  paymentNumber String
  tenantId      String?
  customerId    String?
  supplierId    String?
  invoiceId     String?
  purchaseId    String?
  amount        Float
  paymentDate   DateTime     @default(now())
  paymentMethod String
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  ledger        LedgerEntry?
  customer      Customer?    @relation(fields: [customerId], references: [id])
  invoice       Invoice?     @relation(fields: [invoiceId], references: [id])
  purchase      Purchase?    @relation(fields: [purchaseId], references: [id])
  supplier      Supplier?    @relation(fields: [supplierId], references: [id])
  tenant        Tenant?      @relation(fields: [tenantId], references: [id])

  @@unique([paymentNumber, tenantId])
  @@index([customerId])
  @@index([supplierId])
  @@index([invoiceId])
  @@index([purchaseId])
  @@index([tenantId])
}

model LedgerEntry {
  id          String    @id @default(cuid())
  tenantId    String?
  customerId  String?
  supplierId  String?
  invoiceId   String?   @unique
  purchaseId  String?   @unique
  paymentId   String?   @unique
  type        String
  amount      Float
  description String
  createdAt   DateTime  @default(now())
  customer    Customer? @relation(fields: [customerId], references: [id])
  invoice     Invoice?  @relation(fields: [invoiceId], references: [id])
  payment     Payment?  @relation(fields: [paymentId], references: [id])
  purchase    Purchase? @relation(fields: [purchaseId], references: [id])
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
  tenant      Tenant?   @relation(fields: [tenantId], references: [id])

  @@index([customerId])
  @@index([supplierId])
  @@index([tenantId])
}

model Tenant {
  id            String             @id @default(cuid())
  businessName  String
  ownerName     String
  email         String             @unique
  phone         String?
  gstNumber     String?
  address       String?
  status        String             @default("ACTIVE")
  businessType  BusinessType       @default(GENERAL_RETAIL)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  categories    Category[]
  customers     Customer[]
  invoices      Invoice[]
  invoiceItems  InvoiceLineItem[]
  ledger        LedgerEntry[]
  payments      Payment[]
  products      Product[]
  purchases     Purchase[]
  purchaseItems PurchaseLineItem[]
  suppliers     Supplier[]
  settings      TenantSetting?
  owner             User?
  backups           Backup[]
  cashBooks         CashBook[]
  cashTransactions  CashTransaction[]
  cashBookAuditLogs CashBookAuditLog[]
  staffUsers        StaffUser[]
  priceOverrides    PriceOverrideLog[]
}

model User {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  email        String   @unique
  passwordHash String
  failedLoginAttempts Int @default(0)
  lockedUntil         DateTime?
  emailVerified Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

enum StaffRole {
  OWNER
  SALESMAN
}

model StaffUser {
  id           String    @id @default(cuid())
  tenantId     String
  name         String
  email        String    @unique
  passwordHash String
  role         StaffRole @default(SALESMAN)
  canOverridePrice Boolean @default(false)
  isActive     Boolean   @default(true)
  failedLoginAttempts Int @default(0)
  lockedUntil         DateTime?
  lastLoginAt  DateTime?
  emailVerified Boolean @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model SuperAdmin {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  adminType    String     @default("ROOT")
  status       String     @default("ACTIVE")
  failedLoginAttempts Int @default(0)
  lockedUntil         DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]
}

model AuthSession {
  id           String    @id @default(cuid())
  tokenId      String    @unique
  subjectType  String
  tenantId     String?
  userId       String?
  superAdminId String?
  status       String    @default("ACTIVE")
  expiresAt    DateTime
  revokedAt    DateTime?
  lastSeenAt   DateTime  @default(now())
  ipAddress    String?
  userAgent    String?
  browser      String?
  operatingSystem String?
  lastActivity DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([tenantId])
  @@index([userId])
  @@index([superAdminId])
  @@index([status, expiresAt])
}

model RefreshToken {
  id        String    @id @default(cuid())
  tenantId  String?
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  ipAddress String?
  userAgent String?

  @@index([userId])
  @@index([tokenHash])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([tokenHash])
}

model EmailVerificationToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([tokenHash])
}

/// Authentication Audit Log
/// Tracks authentication and security events per tenant/user
model AuthenticationAuditLog {
  id             String   @id @default(cuid())
  tenantId       String?
  ownerId        String?
  staffId        String?
  eventType      String
  status         String
  description    String?
  ipAddress      String?
  userAgent      String?
  browser        String?
  operatingSystem String?
  deviceType     String?
  country        String?
  city           String?
  sessionId      String?
  createdAt      DateTime @default(now())

  @@index([tenantId])
  @@index([ownerId])
  @@index([staffId])
  @@index([eventType])
  @@index([createdAt])
}

model TenantSetting {
  id                String   @id @default(cuid())
  tenantId          String   @unique
  businessName      String?
  gstNumber         String?
  invoicePrefix     String   @default("INV-")
  lowStockThreshold Int      @default(10)
  defaultGst        Int      @default(18)
  taxCalculation    Boolean  @default(true)
  encryptedSecrets  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

/// AUDIT LOG MODEL - Production Security
///
/// Tracks all administrative actions performed by Super Admins
/// for security monitoring and compliance.
///
/// Actions tracked:
/// - tenant creation
/// - tenant suspension/reactivation
/// - password resets
/// - settings changes
/// - user management
///
/// Fields:
/// - adminId: Super admin who performed action
/// - action: Action type (e.g., "TENANT_CREATED", "TENANT_SUSPENDED")
/// - targetType: Type of resource affected (e.g., "TENANT", "USER")
/// - targetId: ID of affected resource
/// - metadata: JSON metadata (reason, old values, new values, etc.)
/// - ipAddress: Admin's IP address for security tracking
/// - userAgent: Admin's user agent
/// - createdAt: When action occurred
model AuditLog {
  id         String     @id @default(cuid())
  adminId    String
  action     String
  actionType String     @default("ADMIN_ACTION")
  targetType String
  targetId   String?
  ipAddress  String?
  userAgent  String?
  metadata   String?
  createdAt  DateTime   @default(now())
  superAdmin SuperAdmin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([action])
  @@index([targetType])
  @@index([targetId])
  @@index([createdAt])
}

model Backup {
  id          String   @id @default(cuid())
  tenantId    String?
  type        String   // "MONTHLY" or "YEARLY"
  year        Int
  month       Int?     // 1-12 for monthly, null for yearly
  data        Json     // Snapshot of sales, inventory, customers, suppliers, payments, orders
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, type, year, month])
  @@index([tenantId])
}

enum CashBookStatus {
  OPEN
  CLOSED
}

enum CashDirection {
  IN
  OUT
}

enum CashTransactionType {
  CASH_SALE
  CUSTOMER_PAYMENT
  EXPENSE
  ANGADIYA_PAYMENT
  STAFF_CASH_TAKEN
  OWNER_WITHDRAWAL
  PERSONAL_EXPENSE
  TEMPORARY_CASH_ADVANCE
  LOAN_GIVEN
  LOAN_RECEIVED
  BANK_DEPOSIT
  BANK_WITHDRAWAL
  OTHER
}

model CashBook {
  id             String             @id @default(cuid())
  tenantId       String
  date           DateTime
  openingBalance Decimal            @db.Decimal(12, 2)
  totalCashIn    Decimal            @default(0) @db.Decimal(12, 2)
  totalCashOut   Decimal            @default(0) @db.Decimal(12, 2)
  closingBalance Decimal            @db.Decimal(12, 2)
  status         CashBookStatus
  closedAt       DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  tenant         Tenant             @relation(fields: [tenantId], references: [id])
  transactions   CashTransaction[]
  auditLogs      CashBookAuditLog[]

  @@unique([tenantId, date])
  @@index([tenantId])
}

model CashTransaction {
  id                 String              @id @default(cuid())
  tenantId           String
  cashBookId         String
  type               CashTransactionType
  direction          CashDirection
  amount             Decimal             @db.Decimal(12, 2)
  description        String?
  personName         String?
  mobile             String?
  purpose            String?
  expectedReturnDate DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  cashBook           CashBook            @relation(fields: [cashBookId], references: [id])

  @@index([tenantId])
  @@index([cashBookId])
}

model CashBookAuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  cashBookId String
  userId     String
  action     String
  createdAt  DateTime @default(now())
  cashBook   CashBook @relation(fields: [cashBookId], references: [id], onDelete: Cascade)
  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([cashBookId])
}

model PriceOverrideLog {
  id            String   @id @default(cuid())
  tenantId      String
  invoiceId     String
  productId     String
  originalPrice Float
  soldPrice     Float
  discount      Float
  userId        String?
  userName      String?
  createdAt     DateTime @default(now())

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [productId], references: [id])

  @@index([tenantId])
  @@index([invoiceId])
  @@index([productId])
}
