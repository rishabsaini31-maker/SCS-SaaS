generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id               String    @id @default(cuid())
  name             String
  category         String?
  purchasePrice    Float     @default(0)
  sellingPrice     Float     @default(0)
  gst              Float     @default(0)
  stock            Int       @default(0)
  barcode          String?
  image            String?
  status           String    @default("active")
  tenantId         String?
  tenant           Tenant?   @relation(fields: [tenantId], references: [id])
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  invoiceItems     InvoiceLineItem[]
  purchaseItems    PurchaseLineItem[]
  @@index([tenantId])
  @@unique([barcode, tenantId])
}

model Customer {
  id                  String    @id @default(cuid())
  name                String
  email               String?
  phone               String?
  address             String?
  gstin               String?
  outstandingBalance  Float     @default(0)
  status              String    @default("active")
  tenantId            String?
  tenant              Tenant?   @relation(fields: [tenantId], references: [id])
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  invoices            Invoice[]
  payments            Payment[]
  ledgers             LedgerEntry[]
  @@index([tenantId])
  @@unique([email, tenantId])
  @@unique([gstin, tenantId])
}

model Supplier {
  id              String    @id @default(cuid())
  name            String
  email           String?
  phone           String?
  address         String?
  gstin           String?
  payableBalance  Float     @default(0)
  status          String    @default("active")
  tenantId        String?
  tenant          Tenant?   @relation(fields: [tenantId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  purchases       Purchase[]
  payments        Payment[]
  ledgers         LedgerEntry[]
  @@index([tenantId])
  @@unique([email, tenantId])
  @@unique([gstin, tenantId])
}

model Invoice {
  id              String    @id @default(cuid())
  invoiceNumber   String
  tenantId        String?
  tenant          Tenant?   @relation(fields: [tenantId], references: [id])
  customerId      String
  customer        Customer  @relation(fields: [customerId], references: [id])
  invoiceDate     DateTime  @default(now())
  subtotal        Float     @default(0)
  gstAmount       Float     @default(0)
  totalAmount     Float     @default(0)
  status          String    @default("created")
  notes           String?
  lineItems       InvoiceLineItem[]
  payments        Payment[]
  ledger          LedgerEntry?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  @@index([customerId])
  @@index([tenantId])
  @@unique([invoiceNumber, tenantId])
}

model InvoiceLineItem {
  id          String    @id @default(cuid())
  tenantId    String?
  tenant      Tenant?   @relation(fields: [tenantId], references: [id])
  invoiceId   String
  invoice     Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  quantity    Int
  unitPrice   Float
  totalPrice  Float
  createdAt   DateTime  @default(now())
  @@index([invoiceId])
  @@index([productId])
  @@index([tenantId])
}

model Purchase {
  id              String    @id @default(cuid())
  purchaseNumber  String
  tenantId        String?
  tenant          Tenant?   @relation(fields: [tenantId], references: [id])
  supplierId      String
  supplier        Supplier  @relation(fields: [supplierId], references: [id])
  purchaseDate    DateTime  @default(now())
  subtotal        Float     @default(0)
  gstAmount       Float     @default(0)
  totalAmount     Float     @default(0)
  status          String    @default("created")
  notes           String?
  lineItems       PurchaseLineItem[]
  payments        Payment[]
  ledger          LedgerEntry?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  @@index([supplierId])
  @@index([tenantId])
  @@unique([purchaseNumber, tenantId])
}

model PurchaseLineItem {
  id          String    @id @default(cuid())
  tenantId    String?
  tenant      Tenant?   @relation(fields: [tenantId], references: [id])
  purchaseId  String
  purchase    Purchase  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product?  @relation(fields: [productId], references: [id])
  productName String?
  category    String?
  quantity    Int
  unitPrice   Float
  totalPrice  Float
  createdAt   DateTime  @default(now())
  @@index([purchaseId])
  @@index([productId])
  @@index([tenantId])
}

model Payment {
  id              String    @id @default(cuid())
  paymentNumber   String
  tenantId        String?
  tenant          Tenant?   @relation(fields: [tenantId], references: [id])
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id])
  supplierId      String?
  supplier        Supplier? @relation(fields: [supplierId], references: [id])
  invoiceId       String?
  invoice         Invoice?  @relation(fields: [invoiceId], references: [id])
  purchaseId      String?
  purchase        Purchase? @relation(fields: [purchaseId], references: [id])
  amount          Float
  paymentDate     DateTime  @default(now())
  paymentMethod   String
  notes           String?
  ledger          LedgerEntry?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  @@index([customerId])
  @@index([supplierId])
  @@index([invoiceId])
  @@index([purchaseId])
  @@index([tenantId])
  @@unique([paymentNumber, tenantId])
}

model LedgerEntry {
  id          String    @id @default(cuid())
  tenantId    String?
  tenant      Tenant?   @relation(fields: [tenantId], references: [id])
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])
  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
  invoiceId   String?   @unique
  invoice     Invoice?  @relation(fields: [invoiceId], references: [id])
  purchaseId  String?   @unique
  purchase    Purchase? @relation(fields: [purchaseId], references: [id])
  paymentId   String?   @unique
  payment     Payment?  @relation(fields: [paymentId], references: [id])
  type        String
  amount      Float
  description String
  createdAt   DateTime  @default(now())
  @@index([customerId])
  @@index([supplierId])
  @@index([tenantId])
}

model Tenant {
  id             String   @id @default(cuid())
  businessName   String
  ownerName      String
  email          String   @unique
  phone          String?
  gstNumber      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  products       Product[]
  customers      Customer[]
  suppliers      Supplier[]
  invoices       Invoice[]
  invoiceItems   InvoiceLineItem[]
  purchases      Purchase[]
  purchaseItems  PurchaseLineItem[]
  payments       Payment[]
  ledger         LedgerEntry[]
  settings       TenantSetting?
}

model TenantSetting {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  businessName    String?
  gstNumber       String?
  invoicePrefix   String   @default("INV-")
  lowStockThreshold Int     @default(10)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
}
